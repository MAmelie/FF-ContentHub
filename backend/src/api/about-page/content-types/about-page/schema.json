{
  "kind": "singleType",
  "collectionName": "about_pages",
  "info": {
    "singularName": "about-page",
    "pluralName": "about-pages",
    "displayName": "About Page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "text",
      "required": false
    },
    "intro": {
      "type": "richtext",
      "required": false
    },
    "mission": {
      "type": "richtext",
      "required": false
    },
    "hero_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "team_members": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::team-member.team-member"
    }
  }
}
