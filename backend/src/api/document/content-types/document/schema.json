      "required": true,
      "allowedTypes": ["files", "audios"]
    },
    "order": {
      "type": "integer"
    },
    "publishedDate": {
      "type": "date"
    },
    "sessionGroup": {
      "type": "string"
    },
    "sessionSubGroup": {
      "type": "string"
    }
  }
}
